<odoo>

    <record id="view_sale_analysis_report_wizard_form" model="ir.ui.view">
        <field name="name">sale.analysis.report.wizard.form</field>
        <field name="model">sale.analysis.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Rapport Analyse Ventes (Sage)">
                <sheet>
                    <div class="oe_title">
                        <h1>Rapport Analyse Ventes (Format Sage)</h1>
                        <p class="text-muted">
                            Genere un rapport Excel format Sage 100 - 19 colonnes
                            pour analyse TCD.
                        </p>
                    </div>
                    <div class="alert alert-info" role="alert">
                        <strong>Sources incluses :</strong>
                        <ul class="mb-1">
                            <li>Factures clients (out_invoice) et avoirs (out_refund) - postees ou brouillons (option)</li>
                            <li>Devis non transformes (etat Brouillon, Envoye)</li>
                            <li>Bons de commande non encore factures totalement (qty_to_invoice &gt; 0)</li>
                        </ul>
                        <em>Anti-doublon : les commandes completement facturees sont comptees une seule fois (cote facture).</em>
                        <br/><em>POS : les factures issues du POS sont exclues.</em>
                    </div>
                    <group>
                        <group string="Periode">
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Options">
                            <field name="include_draft"/>
                        </group>
                    </group>
                    <group string="Filtres optionnels">
                        <group>
                            <field name="partner_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="pricelist_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="category_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <!-- Zone telechargement (visible apres generation) -->
                    <group string="Telechargement"
                           invisible="not report_xlsx_file">
                        <field name="report_xlsx_file"
                               filename="report_xlsx_filename"
                               readonly="1"/>
                        <field name="report_xlsx_filename" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate_report" type="object"
                            string="Generer le rapport" class="btn-primary"
                            icon="fa-file-excel-o"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sale_analysis_report_wizard" model="ir.actions.act_window">
        <field name="name">Rapport Analyse Ventes (Sage)</field>
        <field name="res_model">sale.analysis.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
